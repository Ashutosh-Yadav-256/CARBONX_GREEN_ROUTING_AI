# ─── LLM (Ollama) ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ─── Image Generation ────────────────────────────
IMAGE_MODEL_ID=runwayml/stable-diffusion-v1-5
IMAGE_INFERENCE_STEPS=25
IMAGE_USE_GPU=auto
IMAGE_FALLBACK_MODE=true

# ─── Search ──────────────────────────────────────
SEARCH_MAX_RESULTS=5

# ─── RAG ─────────────────────────────────────────
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3

# ─── Server ──────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=*
